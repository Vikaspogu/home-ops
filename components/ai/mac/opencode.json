{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "provider": {
    "inference-hub": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA Inference Hub",
      "options": {
        "baseURL": "https://inference-api.nvidia.com/v1",
        "apiKey": "{env:INFERENCE_HUB_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "aws/anthropic/bedrock-claude-opus-4-8": {
          "name": "Claude Opus 4.8"
        },
        "azure/openai/gpt-5.5": {
          "name": "GPT-5.5"
        },
        "nvidia/minimaxai/minimax-m2.7": {
          "name": "Minimax M2.7"
        }
      }
    }
  },
  "model": "inference-hub/aws/anthropic/bedrock-claude-opus-4-8",
  "small_model": "inference-hub/azure/openai/gpt-5.5",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "inference-hub/aws/anthropic/bedrock-claude-opus-4-8",
      "temperature": 0.2,
      "permission": {
        "*": "allow"
      }
    },
    "review": {
      "description": "Review code for bugs, regressions, security issues, and missing tests.",
      "mode": "primary",
      "model": "inference-hub/azure/openai/gpt-5.5",
      "permission": {
        "*": "allow"
      }
    },
    "review-minimax": {
      "description": "Review code using Minimax as a non-Claude independent confidence check.",
      "mode": "subagent",
      "model": "inference-hub/nvidia/minimaxai/minimax-m2.7",
      "permission": {
        "*": "allow"
      }
    }
  }
}
